{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "reports":     { ".indexOn": ["createdAt", "propId", "visitId", "clientId"] },
    "requests":    { ".indexOn": ["createdAt", "clientId", "propId", "status"] },
    "visits":      { ".indexOn": ["date", "propId", "status"] },
    "properties":  { ".indexOn": ["clientId", "tariff", "status"] },
    "invoices":    { ".indexOn": ["createdAt", "clientId", "propId", "status", "period"] },
    "clients":     { ".indexOn": ["tgChatId", "accessToken", "lang"] },
    "leads":       { ".indexOn": ["createdAt", "status", "lang", "city"] },
    "notifications": { ".indexOn": ["createdAt"] }
  }
}
